<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0a0a0a">
<title>RANGE 1</title>
<style>
:root{
  --bg:#0a0a0a;--bg2:#111;--bg3:#1a1a1a;--bg4:#222;
  --b1:#2a2a2a;--b2:#333;
  --ac:#c8a84b;--ac2:#e8c86b;--ac3:#8b6914;
  --rd:#c0392b;--rd2:#e74c3c;
  --gr:#27ae60;--gr2:#2ecc71;
  --bl:#2980b9;--bl2:#3498db;
  --t1:#e8e8e8;--t2:#a0a0a0;--t3:#606060;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{background:var(--bg);color:var(--t1);font-family:-apple-system,'Helvetica Neue',sans-serif;min-height:100vh;overflow-x:hidden;}
button{touch-action:manipulation;cursor:pointer;border:none;outline:none;}

/* ── SCREENS ── */
.scr{display:none;min-height:100vh;flex-direction:column;}
.scr.on{display:flex;}

/* ── SETUP SCREEN ── */
#setup{background:var(--bg);padding:0;}
.setup-header{padding:56px 24px 24px;text-align:center;border-bottom:1px solid var(--b1);}
.setup-title{font-size:36px;font-weight:800;letter-spacing:8px;color:var(--ac);margin-bottom:4px;}
.setup-sub{font-size:11px;color:var(--t3);letter-spacing:4px;}
.setup-body{flex:1;overflow-y:auto;padding:24px 20px 40px;}
.field-group{margin-bottom:24px;}
.field-label{font-size:10px;color:var(--ac3);letter-spacing:3px;margin-bottom:8px;display:block;}
.field-input{width:100%;background:var(--bg3);border:1px solid var(--b2);border-radius:8px;padding:14px 16px;color:var(--t1);font-size:18px;font-weight:600;outline:none;-webkit-appearance:none;}
.field-input:focus{border-color:var(--ac3);}
.field-input::placeholder{color:var(--t3);}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

/* Mode selector */
.mode-wrap{display:flex;gap:0;background:var(--bg3);border:1px solid var(--b1);border-radius:8px;overflow:hidden;margin-bottom:24px;}
.mode-btn{flex:1;padding:14px 8px;font-size:13px;font-weight:700;letter-spacing:2px;color:var(--t3);background:transparent;text-align:center;}
.mode-btn.on{background:var(--bg2);color:var(--ac);border-bottom:2px solid var(--ac);}

/* Load presets */
.preset-wrap{display:flex;flex-direction:column;gap:8px;margin-bottom:12px;}
.preset-row{display:grid;grid-template-columns:1fr 80px 44px;gap:8px;align-items:center;background:var(--bg3);border:1px solid var(--b1);border-radius:8px;padding:10px 12px;}
.preset-name{font-size:15px;font-weight:600;color:var(--t1);}
.preset-rounds{background:var(--bg4);border:1px solid var(--b2);border-radius:6px;padding:8px;color:var(--ac);font-size:20px;font-weight:800;text-align:center;width:100%;outline:none;-webkit-appearance:none;}
.preset-del{width:36px;height:36px;background:transparent;border:1px solid rgba(192,57,43,.3);border-radius:6px;color:var(--rd2);font-size:18px;display:flex;align-items:center;justify-content:center;}
.add-preset-btn{width:100%;background:transparent;border:1px dashed var(--b2);border-radius:8px;padding:12px;color:var(--ac);font-size:12px;letter-spacing:3px;font-weight:700;}

/* Start button */
.start-btn{width:100%;background:var(--ac);color:#111;border-radius:12px;padding:18px;font-size:22px;font-weight:800;letter-spacing:4px;margin-top:8px;}
.start-btn:active{transform:scale(.97);}

/* ── LIVE RANGE SCREEN ── */
#live{background:var(--bg);}
.live-header{background:var(--bg2);border-bottom:1px solid var(--b1);padding:52px 18px 14px;display:flex;align-items:center;gap:12px;}
.live-title{font-size:13px;font-weight:800;letter-spacing:4px;color:var(--ac);flex:1;}
.live-mode-tag{font-size:9px;letter-spacing:2px;padding:3px 8px;border-radius:4px;background:rgba(200,168,75,.1);color:var(--ac);border:1px solid var(--ac3);}
.end-btn{background:var(--rd);color:#fff;border-radius:6px;padding:8px 14px;font-size:12px;font-weight:700;letter-spacing:2px;}

/* Big counter */
.counter-wrap{background:var(--bg2);border-bottom:1px solid var(--b1);padding:20px;text-align:center;}
.counter-label{font-size:10px;color:var(--t3);letter-spacing:4px;margin-bottom:4px;}
.counter-num{font-size:88px;font-weight:900;color:var(--ac);line-height:1;letter-spacing:-2px;}
.counter-num.warn{color:#e87d2b;}
.counter-num.danger{color:var(--rd2);}
.counter-sub{font-size:10px;color:var(--t3);letter-spacing:2px;margin-top:4px;}
.counter-stats{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--b1);margin-top:16px;}
.counter-stat{text-align:center;padding:10px 4px;}
.counter-stat:not(:last-child){border-right:1px solid var(--b1);}
.cs-val{font-size:24px;font-weight:800;color:var(--t1);line-height:1;}
.cs-val.red{color:var(--rd2);}
.cs-val.green{color:var(--gr);}
.cs-lbl{font-size:8px;color:var(--t3);letter-spacing:2px;margin-top:3px;}

/* Action buttons */
.actions{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:16px;}
.action-btn{border-radius:12px;padding:20px 12px;display:flex;flex-direction:column;align-items:center;gap:8px;position:relative;overflow:hidden;}
.action-btn:active{transform:scale(.96);}
.action-btn.issue{background:rgba(41,128,185,.15);border:2px solid var(--bl2);}
.action-btn.return{background:rgba(39,174,96,.15);border:2px solid var(--gr2);}
.action-btn.dud{background:rgba(192,57,43,.12);border:2px solid var(--rd2);}
.action-btn.relay{background:rgba(200,168,75,.1);border:2px solid var(--ac);grid-column:1/-1;}
.action-ico{font-size:32px;}
.action-lbl{font-size:14px;font-weight:800;letter-spacing:3px;}
.action-btn.issue .action-lbl{color:var(--bl2);}
.action-btn.return .action-lbl{color:var(--gr2);}
.action-btn.dud .action-lbl{color:var(--rd2);}
.action-btn.relay .action-lbl{color:var(--ac);}
.action-sub{font-size:9px;letter-spacing:1px;color:var(--t3);}

/* Relay info strip */
.relay-strip{background:var(--bg3);border-bottom:1px solid var(--b1);padding:10px 18px;display:flex;align-items:center;gap:12px;}
.relay-num{font-size:13px;font-weight:800;letter-spacing:2px;color:var(--ac);}
.relay-detail{font-size:10px;color:var(--t3);letter-spacing:1px;flex:1;}
.relay-close-btn{font-size:11px;font-weight:700;letter-spacing:2px;color:var(--rd2);background:transparent;border:1px solid rgba(192,57,43,.3);border-radius:4px;padding:4px 10px;}

/* Log */
.log-wrap{flex:1;overflow-y:auto;padding:12px 16px 100px;}
.log-day-label{font-size:9px;color:var(--t3);letter-spacing:3px;text-align:center;padding:8px 0;border-bottom:1px solid var(--b1);margin-bottom:8px;}
.log-item{display:flex;align-items:center;gap:12px;padding:10px 12px;background:var(--bg2);border:1px solid var(--b1);border-radius:8px;margin-bottom:6px;}
.log-item.issue{border-left:3px solid var(--bl2);}
.log-item.return{border-left:3px solid var(--gr2);}
.log-item.dud{border-left:3px solid var(--rd2);}
.log-item.relay-start{border-left:3px solid var(--ac);background:rgba(200,168,75,.05);}
.log-ico{font-size:18px;flex-shrink:0;}
.log-body{flex:1;min-width:0;}
.log-main{font-size:14px;font-weight:700;color:var(--t1);}
.log-detail{font-size:10px;color:var(--t3);letter-spacing:1px;margin-top:2px;}
.log-time{font-size:9px;color:var(--t3);letter-spacing:1px;flex-shrink:0;}
.log-del{background:transparent;border:none;color:var(--t3);font-size:16px;padding:4px 8px;flex-shrink:0;}

/* ── ENTRY MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:500;display:none;align-items:flex-end;backdrop-filter:blur(4px);}
.modal-overlay.open{display:flex;}
.modal-sheet{background:var(--bg2);border-radius:16px 16px 0 0;border-top:1px solid var(--b2);width:100%;padding:20px 20px 48px;}
.modal-handle{width:40px;height:4px;background:var(--b2);border-radius:2px;margin:0 auto 20px;}
.modal-title{font-size:20px;font-weight:800;letter-spacing:4px;margin-bottom:20px;text-align:center;}
.modal-title.issue{color:var(--bl2);}
.modal-title.return{color:var(--gr2);}
.modal-title.dud{color:var(--rd2);}
.modal-title.relay{color:var(--ac);}

/* Quick preset chips in modal */
.preset-chips{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;}
.preset-chip{background:var(--bg3);border:1px solid var(--b2);border-radius:6px;padding:8px 14px;font-size:12px;font-weight:700;letter-spacing:1px;color:var(--t2);}
.preset-chip:active{background:var(--bg4);border-color:var(--ac3);color:var(--ac);}

.big-input-wrap{background:var(--bg3);border:1px solid var(--b2);border-radius:10px;padding:16px;margin-bottom:16px;text-align:center;}
.big-input-label{font-size:9px;color:var(--t3);letter-spacing:3px;margin-bottom:8px;}
.big-input{width:100%;background:transparent;border:none;color:var(--ac);font-size:64px;font-weight:900;text-align:center;outline:none;-webkit-appearance:none;}

/* +/- stepper */
.stepper{display:flex;align-items:center;gap:12px;margin-bottom:20px;}
.stepper-btn{width:56px;height:56px;border-radius:50%;font-size:28px;font-weight:700;display:flex;align-items:center;justify-content:center;background:var(--bg3);border:1px solid var(--b2);color:var(--t1);}
.stepper-btn:active{background:var(--bg4);}
.stepper-val{flex:1;text-align:center;font-size:48px;font-weight:900;color:var(--t1);}

/* Notes field */
.notes-input{width:100%;background:var(--bg3);border:1px solid var(--b2);border-radius:8px;padding:12px;color:var(--t1);font-size:14px;resize:none;outline:none;margin-bottom:16px;}
.notes-input::placeholder{color:var(--t3);}

/* Relay modal extras */
.relay-field-group{margin-bottom:14px;}
.relay-label{font-size:9px;color:var(--t3);letter-spacing:3px;margin-bottom:6px;display:block;}

.confirm-btn{width:100%;border-radius:10px;padding:16px;font-size:20px;font-weight:800;letter-spacing:3px;}
.confirm-btn.issue{background:var(--bl);color:#fff;}
.confirm-btn.return{background:var(--gr);color:#fff;}
.confirm-btn.dud{background:var(--rd);color:#fff;}
.confirm-btn.relay{background:var(--ac);color:#111;}
.confirm-btn:active{transform:scale(.97);}

/* ── SUMMARY SCREEN ── */
#summary{background:var(--bg);}
.summary-header{padding:56px 20px 20px;text-align:center;border-bottom:1px solid var(--b1);}
.summary-title{font-size:28px;font-weight:800;letter-spacing:6px;color:var(--ac);margin-bottom:4px;}
.summary-sub{font-size:10px;color:var(--t3);letter-spacing:3px;}
.summary-body{flex:1;overflow-y:auto;padding:20px 16px 48px;}
.summary-hero{background:var(--bg2);border:1px solid var(--b1);border-radius:12px;padding:20px;margin-bottom:16px;}
.summary-big{font-size:72px;font-weight:900;color:var(--ac);text-align:center;line-height:1;}
.summary-big-label{font-size:10px;color:var(--t3);letter-spacing:3px;text-align:center;margin-top:4px;}
.summary-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;}
.summary-card{background:var(--bg2);border:1px solid var(--b1);border-radius:10px;padding:16px;text-align:center;}
.summary-card-val{font-size:36px;font-weight:900;line-height:1;margin-bottom:4px;}
.summary-card-lbl{font-size:9px;color:var(--t3);letter-spacing:2px;}
.reconcile-card{border-radius:10px;padding:16px;margin-bottom:16px;text-align:center;}
.reconcile-card.balanced{background:rgba(39,174,96,.1);border:1px solid rgba(39,174,96,.3);}
.reconcile-card.unbalanced{background:rgba(192,57,43,.1);border:1px solid rgba(192,57,43,.3);}
.reconcile-status{font-size:22px;font-weight:800;letter-spacing:3px;margin-bottom:4px;}
.reconcile-card.balanced .reconcile-status{color:var(--gr2);}
.reconcile-card.unbalanced .reconcile-status{color:var(--rd2);}
.reconcile-detail{font-size:10px;color:var(--t3);letter-spacing:1px;}
.relay-summary{background:var(--bg2);border:1px solid var(--b1);border-radius:10px;padding:16px;margin-bottom:16px;}
.relay-summary-title{font-size:11px;color:var(--ac3);letter-spacing:3px;margin-bottom:12px;}
.relay-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--b1);}
.relay-row:last-child{border-bottom:none;}
.relay-row-name{font-size:13px;font-weight:700;color:var(--t2);letter-spacing:1px;}
.relay-row-val{font-size:14px;font-weight:800;color:var(--t1);}
.log-section{background:var(--bg2);border:1px solid var(--b1);border-radius:10px;padding:16px;margin-bottom:16px;}
.log-section-title{font-size:11px;color:var(--ac3);letter-spacing:3px;margin-bottom:12px;}
.log-entry{display:flex;gap:10px;padding:6px 0;border-bottom:1px solid var(--b1);font-size:12px;}
.log-entry:last-child{border-bottom:none;}
.log-entry-time{color:var(--t3);flex-shrink:0;letter-spacing:1px;}
.log-entry-text{color:var(--t2);flex:1;}
.share-btn{width:100%;background:var(--ac);color:#111;border-radius:10px;padding:16px;font-size:18px;font-weight:800;letter-spacing:3px;margin-bottom:10px;}
.share-btn:active{transform:scale(.97);}
.new-range-btn{width:100%;background:transparent;border:1px solid var(--b2);color:var(--t3);border-radius:10px;padding:14px;font-size:16px;font-weight:700;letter-spacing:3px;}
.new-range-btn:active{background:var(--bg3);}

/* Toast */
.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--bg3);border:1px solid var(--b2);border-radius:8px;padding:11px 18px;font-size:11px;letter-spacing:2px;color:var(--t2);z-index:9999;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.toast.ok{border-color:var(--gr);color:var(--gr2);}
.toast.er{border-color:var(--rd);color:var(--rd2);}
</style>
</head>
<body>

<!-- ── SETUP SCREEN ── -->
<div id="setup" class="scr on">
  <div class="setup-header">
    <div class="setup-title">RANGE 1</div>
    <div class="setup-sub">AMMO ACCOUNTABILITY SYSTEM</div>
  </div>
  <div class="setup-body">

    <div class="field-group">
      <label class="field-label">RANGE NAME / DATE</label>
      <input class="field-input" id="s-name" placeholder="9MM PISTOL · 4 APR 2026" autocomplete="off">
    </div>

    <div class="field-group">
      <label class="field-label">TOTAL ROUNDS ON HAND</label>
      <input class="field-input" id="s-total" type="number" inputmode="numeric" placeholder="0">
    </div>

    <div class="field-group">
      <label class="field-label">CALIBER</label>
      <input class="field-input" id="s-caliber" placeholder="9MM / 5.56 / .50 CAL" autocomplete="off">
    </div>

    <div class="field-group">
      <label class="field-label">RANGE MODE</label>
      <div class="mode-wrap">
        <button class="mode-btn on" id="mode-freeform" onclick="setMode('freeform')">FREEFORM</button>
        <button class="mode-btn" id="mode-relay" onclick="setMode('relay')">RELAY</button>
      </div>
      <div style="font-size:10px;color:var(--t3);letter-spacing:1px;line-height:1.8;" id="mode-desc">
        Issue and return rounds freely. Good for zero range or unstructured shooting.
      </div>
    </div>

    <div class="field-group" id="relay-size-wrap" style="display:none;">
      <label class="field-label">SHOOTERS PER RELAY</label>
      <input class="field-input" id="s-relay-size" type="number" inputmode="numeric" placeholder="10">
    </div>

    <div class="field-group">
      <label class="field-label">STANDARD LOAD PRESETS</label>
      <div style="font-size:10px;color:var(--t3);letter-spacing:1px;margin-bottom:10px;line-height:1.8;">
        Define your standard mag loads. Tap these in the issue screen for fast entry.
      </div>
      <div class="preset-wrap" id="preset-list"></div>
      <button class="add-preset-btn" onclick="addPreset()">+ ADD LOAD PRESET</button>
    </div>

    <button class="start-btn" onclick="startRange()">START RANGE</button>

  </div>
</div>

<!-- ── LIVE RANGE SCREEN ── -->
<div id="live" class="scr">

  <div class="live-header">
    <div>
      <div class="live-title" id="live-name">RANGE 1</div>
      <div style="font-size:9px;color:var(--t3);letter-spacing:2px;margin-top:2px;" id="live-caliber"></div>
    </div>
    <div class="live-mode-tag" id="live-mode-tag">FREEFORM</div>
    <button class="end-btn" onclick="confirmEndRange()">END RANGE</button>
  </div>

  <!-- Big counter -->
  <div class="counter-wrap">
    <div class="counter-label">ROUNDS REMAINING</div>
    <div class="counter-num" id="counter">0</div>
    <div class="counter-sub" id="counter-sub">OF 0 TOTAL</div>
    <div class="counter-stats">
      <div class="counter-stat">
        <div class="cs-val red" id="stat-issued">0</div>
        <div class="cs-lbl">ISSUED</div>
      </div>
      <div class="counter-stat">
        <div class="cs-val green" id="stat-returned">0</div>
        <div class="cs-lbl">RETURNED</div>
      </div>
      <div class="counter-stat">
        <div class="cs-val red" id="stat-duds">0</div>
        <div class="cs-lbl">DUDS</div>
      </div>
    </div>
  </div>

  <!-- Relay strip — shown in relay mode -->
  <div class="relay-strip" id="relay-strip" style="display:none;">
    <div>
      <div class="relay-num" id="relay-num">RELAY 1</div>
      <div class="relay-detail" id="relay-detail">NO ACTIVE RELAY</div>
    </div>
    <button class="relay-close-btn" id="relay-close-btn" onclick="closeRelay()" style="display:none;">CLOSE RELAY</button>
  </div>

  <!-- Action buttons -->
  <div class="actions">
    <button class="action-btn issue" onclick="openModal('issue')">
      <span class="action-ico">📤</span>
      <span class="action-lbl">ISSUE</span>
      <span class="action-sub">SEND ROUNDS OUT</span>
    </button>
    <button class="action-btn return" onclick="openModal('return')">
      <span class="action-ico">📥</span>
      <span class="action-lbl">RETURN</span>
      <span class="action-sub">UNFIRED ROUNDS BACK</span>
    </button>
    <button class="action-btn dud" onclick="openModal('dud')">
      <span class="action-ico">⚠️</span>
      <span class="action-lbl">DUD / MISFIRE</span>
      <span class="action-sub">LOG UNSERVICEABLE ROUND</span>
    </button>
    <button class="action-btn relay" id="relay-btn" onclick="openModal('relay')" style="display:none;">
      <span class="action-ico">🔄</span>
      <span class="action-lbl">NEW RELAY</span>
      <span class="action-sub">START NEXT GROUP</span>
    </button>
  </div>

  <!-- Live log -->
  <div class="log-wrap" id="live-log">
    <div style="text-align:center;padding:30px 0;font-size:10px;color:var(--t3);letter-spacing:3px;" id="log-empty">
      NO ACTIVITY YET — TAP ISSUE TO START
    </div>
  </div>

</div>

<!-- ── SUMMARY SCREEN ── -->
<div id="summary" class="scr">
  <div class="summary-header">
    <div class="summary-title">END OF RANGE</div>
    <div class="summary-sub" id="sum-name-sub"></div>
  </div>
  <div class="summary-body" id="summary-body"></div>
</div>

<!-- ── ENTRY MODAL ── -->
<div class="modal-overlay" id="modal" onclick="handleModalOverlayClick(event)">
  <div class="modal-sheet" id="modal-sheet">
    <div class="modal-handle"></div>
    <div class="modal-title" id="modal-title">ISSUE</div>
    <div id="modal-body"></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ── STATE ──────────────────────────────────────────────────────
var S = {
  name: '',
  caliber: '',
  total: 0,
  mode: 'freeform',
  relaySize: 10,
  presets: [],
  // Live
  remaining: 0,
  issued: 0,
  returned: 0,
  duds: 0,
  log: [],
  relays: [],
  currentRelay: null,
  relayCount: 0,
  startTime: null
};

var _modalType = null;

// ── SETUP ─────────────────────────────────────────────────────
function setMode(m) {
  S.mode = m;
  document.getElementById('mode-freeform').classList.toggle('on', m === 'freeform');
  document.getElementById('mode-relay').classList.toggle('on', m === 'relay');
  document.getElementById('relay-size-wrap').style.display = m === 'relay' ? 'block' : 'none';
  document.getElementById('mode-desc').textContent = m === 'relay'
    ? 'Structured relay mode. Each group of shooters is tracked as a relay with its own issue/return log.'
    : 'Issue and return rounds freely. Good for zero range or unstructured shooting.';
}

var _presets = [];

function addPreset(name, rounds) {
  _presets.push({ id: Date.now() + Math.random(), name: name || '', rounds: rounds || 10 });
  renderPresets();
}

function removePreset(id) {
  _presets = _presets.filter(function(p) { return p.id !== id; });
  renderPresets();
}

function renderPresets() {
  var el = document.getElementById('preset-list');
  if (!_presets.length) { el.innerHTML = ''; return; }
  el.innerHTML = _presets.map(function(p) {
    return '<div class="preset-row" id="pr-' + p.id + '">' +
      '<input class="preset-name field-input" value="' + esc(p.name) + '" placeholder="e.g. M4 QUAL" ' +
        'onchange="updatePreset(' + p.id + ',\'name\',this.value)" style="background:var(--bg4);border:none;padding:8px;">' +
      '<input class="preset-rounds" type="number" inputmode="numeric" value="' + p.rounds + '" ' +
        'onchange="updatePreset(' + p.id + ',\'rounds\',this.value)">' +
      '<button class="preset-del" onclick="removePreset(' + p.id + ')">✕</button>' +
    '</div>';
  }).join('');
}

function updatePreset(id, key, val) {
  var p = _presets.find(function(x) { return x.id === id; });
  if (p) p[key] = key === 'rounds' ? (parseInt(val) || 0) : val;
}

function startRange() {
  var name = document.getElementById('s-name').value.trim();
  var total = parseInt(document.getElementById('s-total').value) || 0;
  var caliber = document.getElementById('s-caliber').value.trim();
  if (!total) { toast('ENTER TOTAL ROUNDS ON HAND', 'er'); return; }
  if (!name) name = 'RANGE · ' + new Date().toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}).toUpperCase();

  S.name = name;
  S.caliber = caliber;
  S.total = total;
  S.mode = document.getElementById('mode-relay').classList.contains('on') ? 'relay' : 'freeform';
  S.relaySize = parseInt(document.getElementById('s-relay-size').value) || 10;
  S.presets = _presets.slice();
  S.remaining = total;
  S.issued = 0;
  S.returned = 0;
  S.duds = 0;
  S.log = [];
  S.relays = [];
  S.currentRelay = null;
  S.relayCount = 0;
  S.startTime = new Date();

  document.getElementById('live-name').textContent = name;
  document.getElementById('live-caliber').textContent = caliber ? caliber + ' · ' + total.toLocaleString() + ' ROUNDS' : total.toLocaleString() + ' ROUNDS';
  document.getElementById('live-mode-tag').textContent = S.mode.toUpperCase();
  document.getElementById('relay-btn').style.display = S.mode === 'relay' ? 'flex' : 'none';
  document.getElementById('relay-strip').style.display = S.mode === 'relay' ? 'flex' : 'none';

  updateCounter();
  renderLiveLog();
  go('live');
  toast('RANGE STARTED · ' + total.toLocaleString() + ' ROUNDS', 'ok');
}

// ── LIVE RANGE ─────────────────────────────────────────────────
function updateCounter() {
  var el = document.getElementById('counter');
  var pct = S.total > 0 ? S.remaining / S.total : 1;
  el.textContent = S.remaining.toLocaleString();
  el.className = 'counter-num' + (pct < 0.1 ? ' danger' : pct < 0.25 ? ' warn' : '');
  document.getElementById('counter-sub').textContent = 'OF ' + S.total.toLocaleString() + ' TOTAL · ' + S.issued.toLocaleString() + ' FIRED/OUT';
  document.getElementById('stat-issued').textContent = S.issued.toLocaleString();
  document.getElementById('stat-returned').textContent = S.returned.toLocaleString();
  document.getElementById('stat-duds').textContent = S.duds.toLocaleString();
  updateRelayStrip();
}

function updateRelayStrip() {
  if (S.mode !== 'relay') return;
  var numEl = document.getElementById('relay-num');
  var detEl = document.getElementById('relay-detail');
  var closeBtn = document.getElementById('relay-close-btn');
  if (S.currentRelay) {
    numEl.textContent = 'RELAY ' + S.currentRelay.num;
    detEl.textContent = S.currentRelay.issued + ' ISSUED · ' + S.currentRelay.returned + ' RETURNED · ' + S.currentRelay.shooters + ' SHOOTERS';
    closeBtn.style.display = 'block';
  } else {
    numEl.textContent = 'RELAY ' + (S.relayCount + 1);
    detEl.textContent = 'TAP NEW RELAY TO START';
    closeBtn.style.display = 'none';
  }
}

function renderLiveLog() {
  var el = document.getElementById('live-log');
  var empty = document.getElementById('log-empty');
  if (!S.log.length) {
    if (empty) empty.style.display = 'block';
    // Remove all log items
    el.querySelectorAll('.log-item').forEach(function(x) { x.remove(); });
    return;
  }
  if (empty) empty.style.display = 'none';
  el.innerHTML = S.log.slice().reverse().map(function(entry, i) {
    var typeMap = {
      issue: { ico: '📤', cls: 'issue', label: 'ISSUED' },
      return: { ico: '📥', cls: 'return', label: 'RETURNED' },
      dud: { ico: '⚠️', cls: 'dud', label: 'DUD' },
      relay: { ico: '🔄', cls: 'relay-start', label: '' }
    };
    var t = typeMap[entry.type] || typeMap.issue;
    var main = entry.type === 'relay'
      ? 'RELAY ' + entry.relayNum + ' STARTED · ' + entry.shooters + ' SHOOTERS'
      : t.label + ' ' + entry.rounds + ' RDS' + (entry.notes ? ' — ' + entry.notes : '');
    var detail = entry.type === 'relay'
      ? 'STANDARD LOAD: ' + entry.load + ' RDS/SHOOTER'
      : (entry.preset ? entry.preset + ' · ' : '') + (entry.relay ? 'RELAY ' + entry.relay : '');
    return '<div class="log-item ' + t.cls + '" data-idx="' + (S.log.length - 1 - i) + '">' +
      '<span class="log-ico">' + t.ico + '</span>' +
      '<div class="log-body"><div class="log-main">' + main + '</div>' +
      (detail ? '<div class="log-detail">' + esc(detail) + '</div>' : '') +
      '</div>' +
      '<span class="log-time">' + entry.time + '</span>' +
      '<button class="log-del" onclick="deleteLogEntry(' + (S.log.length - 1 - i) + ')">✕</button>' +
    '</div>';
  }).join('');
}

function deleteLogEntry(idx) {
  var entry = S.log[idx];
  if (!entry) return;
  // Reverse the numbers
  if (entry.type === 'issue') { S.issued -= entry.rounds; S.remaining += entry.rounds; }
  if (entry.type === 'return') { S.returned -= entry.rounds; S.remaining -= entry.rounds; }
  if (entry.type === 'dud') { S.duds -= entry.rounds; S.remaining += entry.rounds; }
  S.log.splice(idx, 1);
  updateCounter();
  renderLiveLog();
  toast('ENTRY DELETED · COUNTS ADJUSTED', 'ok');
}

// ── MODAL ──────────────────────────────────────────────────────
function openModal(type) {
  _modalType = type;
  var modal = document.getElementById('modal');
  var title = document.getElementById('modal-title');
  var body = document.getElementById('modal-body');
  title.className = 'modal-title ' + type;

  if (type === 'issue') {
    title.textContent = 'ISSUE ROUNDS';
    body.innerHTML = buildIssueModal();
  } else if (type === 'return') {
    title.textContent = 'ROUNDS RETURNED';
    body.innerHTML = buildReturnModal();
  } else if (type === 'dud') {
    title.textContent = 'LOG DUD / MISFIRE';
    body.innerHTML = buildDudModal();
  } else if (type === 'relay') {
    title.textContent = 'START NEW RELAY';
    body.innerHTML = buildRelayModal();
  }

  modal.classList.add('open');
  // Auto-focus first input
  setTimeout(function() {
    var inp = body.querySelector('input');
    if (inp) inp.focus();
  }, 100);
}

function handleModalOverlayClick(e) {
  if (e.target === document.getElementById('modal')) closeModal();
}

function closeModal() {
  document.getElementById('modal').classList.remove('open');
  _modalType = null;
}

function buildIssueModal() {
  var presetChips = S.presets.length
    ? '<div class="preset-chips">' +
        S.presets.map(function(p) {
          return '<button class="preset-chip" onclick="setIssueAmount(' + p.rounds + ',\'' + esc(p.name) + '\')">' +
            (p.name ? p.name + '<br>' : '') + p.rounds + ' RDS</button>';
        }).join('') +
      '</div>'
    : '';

  return presetChips +
    '<div class="big-input-wrap">' +
      '<div class="big-input-label">ROUNDS BEING ISSUED</div>' +
      '<input class="big-input" id="m-rounds" type="number" inputmode="numeric" placeholder="0" value="">' +
    '</div>' +
    '<div style="display:flex;gap:8px;margin-bottom:16px;">' +
      '<button class="stepper-btn" onclick="adjustInput(\'m-rounds\',-1)" style="flex:1;border-radius:8px;font-size:20px;">−</button>' +
      '<button class="stepper-btn" onclick="adjustInput(\'m-rounds\',1)" style="flex:1;border-radius:8px;font-size:20px;">+</button>' +
      '<button class="stepper-btn" onclick="adjustInput(\'m-rounds\',5)" style="flex:1;border-radius:8px;font-size:16px;">+5</button>' +
      '<button class="stepper-btn" onclick="adjustInput(\'m-rounds\',10)" style="flex:1;border-radius:8px;font-size:16px;">+10</button>' +
    '</div>' +
    '<textarea class="notes-input" id="m-notes" rows="2" placeholder="NOTES (OPTIONAL) — LANE, NAME, MAG ID..."></textarea>' +
    '<button class="confirm-btn issue" onclick="confirmIssue()">CONFIRM ISSUE</button>';
}

function buildReturnModal() {
  return '<div class="big-input-wrap">' +
      '<div class="big-input-label">ROUNDS BEING RETURNED</div>' +
      '<input class="big-input" id="m-rounds" type="number" inputmode="numeric" placeholder="0">' +
    '</div>' +
    '<div style="display:flex;gap:8px;margin-bottom:16px;">' +
      '<button class="stepper-btn" onclick="adjustInput(\'m-rounds\',-1)" style="flex:1;border-radius:8px;font-size:20px;">−</button>' +
      '<button class="stepper-btn" onclick="adjustInput(\'m-rounds\',1)" style="flex:1;border-radius:8px;font-size:20px;">+</button>' +
      '<button class="stepper-btn" onclick="adjustInput(\'m-rounds\',5)" style="flex:1;border-radius:8px;font-size:16px;">+5</button>' +
      '<button class="stepper-btn" onclick="adjustInput(\'m-rounds\',10)" style="flex:1;border-radius:8px;font-size:16px;">+10</button>' +
    '</div>' +
    '<textarea class="notes-input" id="m-notes" rows="2" placeholder="NOTES (OPTIONAL)"></textarea>' +
    '<button class="confirm-btn return" onclick="confirmReturn()">CONFIRM RETURN</button>';
}

function buildDudModal() {
  return '<div style="background:rgba(192,57,43,.08);border:1px solid rgba(192,57,43,.2);border-radius:10px;padding:14px;margin-bottom:16px;font-size:11px;color:var(--rd2);letter-spacing:1px;line-height:1.8;">' +
    'Duds reduce your ROUNDS FIRED count. They will appear on your end-of-range report for accountability.' +
    '</div>' +
    '<div class="big-input-wrap">' +
      '<div class="big-input-label">NUMBER OF DUDS</div>' +
      '<input class="big-input" id="m-rounds" type="number" inputmode="numeric" placeholder="0" value="1">' +
    '</div>' +
    '<div style="display:flex;gap:8px;margin-bottom:16px;">' +
      '<button class="stepper-btn" onclick="adjustInput(\'m-rounds\',-1)" style="flex:1;border-radius:8px;font-size:20px;">−</button>' +
      '<button class="stepper-btn" onclick="adjustInput(\'m-rounds\',1)" style="flex:1;border-radius:8px;font-size:20px;">+</button>' +
    '</div>' +
    '<textarea class="notes-input" id="m-notes" rows="2" placeholder="LANE / SHOOTER / WEAPON SERIAL — ANY DETAIL USEFUL FOR REPORT"></textarea>' +
    '<button class="confirm-btn dud" onclick="confirmDud()">LOG DUD</button>';
}

function buildRelayModal() {
  var defaultLoad = S.presets.length ? S.presets[0].rounds : 20;
  return '<div class="relay-field-group">' +
      '<label class="relay-label">SHOOTERS IN THIS RELAY</label>' +
      '<input class="field-input" id="m-shooters" type="number" inputmode="numeric" value="' + S.relaySize + '">' +
    '</div>' +
    '<div class="relay-field-group">' +
      '<label class="relay-label">ROUNDS PER SHOOTER</label>' +
      (S.presets.length ? '<div class="preset-chips" style="margin-bottom:10px;">' +
        S.presets.map(function(p) {
          return '<button class="preset-chip" onclick="document.getElementById(\'m-load\').value=' + p.rounds + '">' +
            (p.name || '') + ' ' + p.rounds + ' RDS</button>';
        }).join('') +
      '</div>' : '') +
      '<input class="field-input" id="m-load" type="number" inputmode="numeric" value="' + defaultLoad + '">' +
    '</div>' +
    '<div class="relay-field-group">' +
      '<label class="relay-label">RELAY NOTES (OPTIONAL)</label>' +
      '<textarea class="notes-input" id="m-notes" rows="2" placeholder="RELAY NOTES..."></textarea>' +
    '</div>' +
    '<button class="confirm-btn relay" onclick="confirmRelay()">START RELAY</button>';
}

function setIssueAmount(rounds, name) {
  var el = document.getElementById('m-rounds');
  if (el) el.value = rounds;
}

function adjustInput(id, delta) {
  var el = document.getElementById(id);
  if (!el) return;
  var val = parseInt(el.value) || 0;
  el.value = Math.max(0, val + delta);
}

// ── CONFIRM ACTIONS ────────────────────────────────────────────
function confirmIssue() {
  var rounds = parseInt(document.getElementById('m-rounds').value) || 0;
  if (!rounds) { toast('ENTER ROUNDS TO ISSUE', 'er'); return; }
  if (rounds > S.remaining) { toast('NOT ENOUGH ROUNDS REMAINING', 'er'); return; }
  var notes = (document.getElementById('m-notes') || {}).value || '';
  S.issued += rounds;
  S.remaining -= rounds;
  if (S.currentRelay) S.currentRelay.issued += rounds;
  logEntry('issue', rounds, notes);
  closeModal();
  updateCounter();
  renderLiveLog();
  toast('ISSUED ' + rounds + ' · ' + S.remaining.toLocaleString() + ' REMAINING', 'ok');
}

function confirmReturn() {
  var rounds = parseInt(document.getElementById('m-rounds').value) || 0;
  if (!rounds) { toast('ENTER ROUNDS RETURNED', 'er'); return; }
  var notes = (document.getElementById('m-notes') || {}).value || '';
  S.returned += rounds;
  S.remaining += rounds;
  S.issued = Math.max(0, S.issued - rounds); // net fired goes down
  if (S.currentRelay) S.currentRelay.returned += rounds;
  logEntry('return', rounds, notes);
  closeModal();
  updateCounter();
  renderLiveLog();
  toast('RETURNED ' + rounds + ' · ' + S.remaining.toLocaleString() + ' REMAINING', 'ok');
}

function confirmDud() {
  var rounds = parseInt(document.getElementById('m-rounds').value) || 0;
  if (!rounds) { toast('ENTER DUD COUNT', 'er'); return; }
  var notes = (document.getElementById('m-notes') || {}).value || '';
  S.duds += rounds;
  S.remaining -= rounds;
  logEntry('dud', rounds, notes);
  closeModal();
  updateCounter();
  renderLiveLog();
  toast('DUD LOGGED · ' + rounds + ' ROUND' + (rounds > 1 ? 'S' : ''), 'er');
}

function confirmRelay() {
  var shooters = parseInt(document.getElementById('m-shooters').value) || S.relaySize;
  var load = parseInt(document.getElementById('m-load').value) || 20;
  var notes = (document.getElementById('m-notes') || {}).value || '';
  // Close previous relay
  if (S.currentRelay) closeRelay(true);
  S.relayCount++;
  S.currentRelay = { num: S.relayCount, shooters: shooters, load: load, issued: 0, returned: 0, notes: notes };
  S.relays.push(S.currentRelay);
  logEntry('relay', 0, notes, { relayNum: S.relayCount, shooters: shooters, load: load });
  closeModal();
  updateCounter();
  renderLiveLog();
  toast('RELAY ' + S.relayCount + ' STARTED · ' + shooters + ' SHOOTERS', 'ok');
}

function closeRelay(silent) {
  if (!S.currentRelay) return;
  S.currentRelay.closed = true;
  S.currentRelay = null;
  updateRelayStrip();
  if (!silent) toast('RELAY CLOSED', 'ok');
}

function logEntry(type, rounds, notes, extra) {
  var now = new Date();
  var time = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
  var entry = {
    type: type,
    rounds: rounds,
    notes: notes || '',
    time: time,
    ts: now.getTime(),
    relay: S.currentRelay ? S.currentRelay.num : null
  };
  if (extra) Object.assign(entry, extra);
  S.log.push(entry);
}

// ── END OF RANGE ───────────────────────────────────────────────
function confirmEndRange() {
  if (!confirm('END THE RANGE? This will generate your accountability report.')) return;
  if (S.currentRelay) closeRelay(true);
  go('summary');
  renderSummary();
}

function renderSummary() {
  var fired = S.issued - S.returned;
  var accounted = fired + S.returned + S.duds;
  var balanced = accounted === S.total;
  var discrepancy = S.total - accounted;
  document.getElementById('sum-name-sub').textContent = S.name + (S.caliber ? ' · ' + S.caliber : '');

  var relayHTML = '';
  if (S.relays.length) {
    relayHTML = '<div class="relay-summary">' +
      '<div class="relay-summary-title">RELAY BREAKDOWN</div>' +
      S.relays.map(function(r) {
        var rFired = r.issued - r.returned;
        return '<div class="relay-row">' +
          '<span class="relay-row-name">RELAY ' + r.num + ' · ' + r.shooters + ' SHOOTERS</span>' +
          '<span class="relay-row-val">' + rFired + ' FIRED</span>' +
        '</div>';
      }).join('') +
    '</div>';
  }

  var logHTML = '<div class="log-section">' +
    '<div class="log-section-title">FULL ACCOUNTABILITY LOG</div>' +
    S.log.map(function(e) {
      var text = '';
      if (e.type === 'issue') text = 'ISSUED ' + e.rounds + ' RDS' + (e.notes ? ' — ' + e.notes : '') + (e.relay ? ' [RELAY ' + e.relay + ']' : '');
      if (e.type === 'return') text = 'RETURNED ' + e.rounds + ' RDS' + (e.notes ? ' — ' + e.notes : '');
      if (e.type === 'dud') text = 'DUD: ' + e.rounds + ' RDS' + (e.notes ? ' — ' + e.notes : '');
      if (e.type === 'relay') text = 'RELAY ' + e.relayNum + ' STARTED · ' + e.shooters + ' SHOOTERS · ' + e.load + ' RDS/SHOOTER';
      return '<div class="log-entry"><span class="log-entry-time">' + e.time + '</span><span class="log-entry-text">' + esc(text) + '</span></div>';
    }).join('') +
  '</div>';

  var endTime = new Date();
  var duration = Math.round((endTime - S.startTime) / 60000);

  document.getElementById('summary-body').innerHTML =
    '<div class="summary-hero">' +
      '<div class="summary-big">' + fired.toLocaleString() + '</div>' +
      '<div class="summary-big-label">ROUNDS FIRED</div>' +
    '</div>' +
    '<div class="summary-grid">' +
      '<div class="summary-card"><div class="summary-card-val" style="color:var(--t1);">' + S.total.toLocaleString() + '</div><div class="summary-card-lbl">STARTED WITH</div></div>' +
      '<div class="summary-card"><div class="summary-card-val" style="color:var(--ac);">' + S.remaining.toLocaleString() + '</div><div class="summary-card-lbl">REMAINING</div></div>' +
      '<div class="summary-card"><div class="summary-card-val" style="color:var(--gr2);">' + S.returned.toLocaleString() + '</div><div class="summary-card-lbl">RETURNED UNFIRED</div></div>' +
      '<div class="summary-card"><div class="summary-card-val" style="color:var(--rd2);">' + S.duds.toLocaleString() + '</div><div class="summary-card-lbl">DUDS / MISFIRES</div></div>' +
    '</div>' +
    '<div class="reconcile-card ' + (balanced ? 'balanced' : 'unbalanced') + '">' +
      '<div class="reconcile-status">' + (balanced ? '✓ FULLY ACCOUNTED' : '⚠ DISCREPANCY: ' + Math.abs(discrepancy) + ' RDS') + '</div>' +
      '<div class="reconcile-detail">' +
        (balanced
          ? 'FIRED + RETURNED + DUDS = ' + S.total + ' ✓'
          : discrepancy > 0 ? discrepancy + ' ROUNDS UNACCOUNTED FOR — RECOUNT REQUIRED' : Math.abs(discrepancy) + ' ROUNDS OVER — CHECK RETURN COUNT'
        ) +
      '</div>' +
    '</div>' +
    (S.relays.length ? relayHTML : '') +
    '<div style="background:var(--bg2);border:1px solid var(--b1);border-radius:10px;padding:16px;margin-bottom:16px;">' +
      '<div style="font-size:10px;color:var(--ac3);letter-spacing:3px;margin-bottom:8px;">RANGE SUMMARY</div>' +
      '<div style="font-size:12px;color:var(--t2);line-height:2;letter-spacing:1px;">' +
        S.name + (S.caliber ? ' · ' + S.caliber : '') + '<br>' +
        'DURATION: ' + duration + ' MINUTES<br>' +
        'LOG ENTRIES: ' + S.log.length + '<br>' +
        (S.relays.length ? 'RELAYS: ' + S.relays.length + '<br>' : '') +
        'GENERATED: ' + endTime.toLocaleString('en-US', {month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}).toUpperCase() +
      '</div>' +
    '</div>' +
    logHTML +
    '<button class="share-btn" onclick="shareReport()">SHARE / COPY REPORT</button>' +
    '<button class="new-range-btn" onclick="newRange()">START NEW RANGE</button>';
}

function shareReport() {
  var fired = S.issued - S.returned;
  var accounted = fired + S.returned + S.duds;
  var balanced = accounted === S.total;
  var discrepancy = S.total - accounted;
  var endTime = new Date().toLocaleString('en-US', {month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}).toUpperCase();

  var text = '=== RANGE 1 — END OF RANGE REPORT ===\n';
  text += S.name + (S.caliber ? ' · ' + S.caliber : '') + '\n';
  text += endTime + '\n\n';
  text += 'STARTED WITH:    ' + S.total + ' RDS\n';
  text += 'ROUNDS FIRED:    ' + fired + ' RDS\n';
  text += 'RETURNED UNFIRED: ' + S.returned + ' RDS\n';
  text += 'DUDS/MISFIRES:   ' + S.duds + ' RDS\n';
  text += 'REMAINING:       ' + S.remaining + ' RDS\n\n';
  text += balanced ? '✓ FULLY ACCOUNTED\n' : '⚠ DISCREPANCY: ' + Math.abs(discrepancy) + ' RDS\n';

  if (S.relays.length) {
    text += '\n--- RELAY BREAKDOWN ---\n';
    S.relays.forEach(function(r) {
      text += 'RELAY ' + r.num + ' (' + r.shooters + ' SHOOTERS): ' + (r.issued - r.returned) + ' FIRED\n';
    });
  }

  text += '\n--- ACCOUNTABILITY LOG ---\n';
  S.log.forEach(function(e) {
    var line = e.time + ' ';
    if (e.type === 'issue') line += 'ISSUED ' + e.rounds + ' RDS' + (e.notes ? ' — ' + e.notes : '');
    if (e.type === 'return') line += 'RETURNED ' + e.rounds + ' RDS' + (e.notes ? ' — ' + e.notes : '');
    if (e.type === 'dud') line += 'DUD ' + e.rounds + ' RDS' + (e.notes ? ' — ' + e.notes : '');
    if (e.type === 'relay') line += 'RELAY ' + e.relayNum + ' START · ' + e.shooters + ' SHOOTERS';
    text += line + '\n';
  });

  if (navigator.share) {
    navigator.share({ title: 'RANGE 1 REPORT', text: text }).catch(function(){});
  } else if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(function() { toast('REPORT COPIED TO CLIPBOARD', 'ok'); });
  } else {
    // Fallback
    var ta = document.createElement('textarea');
    ta.value = text;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    toast('REPORT COPIED', 'ok');
  }
}

function newRange() {
  if (!confirm('START A NEW RANGE? This will clear all current data.')) return;
  go('setup');
}

// ── UTILS ──────────────────────────────────────────────────────
function go(id) {
  document.querySelectorAll('.scr').forEach(function(s) { s.classList.remove('on'); });
  document.getElementById(id).classList.add('on');
}

function esc(s) {
  return (s || '').toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function toast(msg, type) {
  var el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast show' + (type ? ' ' + type : '');
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(function() { el.className = 'toast'; }, 3000);
}

// Init with one default preset
addPreset('STD LOAD', 10);
</script>
